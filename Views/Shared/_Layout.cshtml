@using System.Security.Claims
@using SLMOFTaxPortal.Helpers

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
    var roleName = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - eDahab GST Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="~/lib/lumen/bootstrap.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.bootstrap5.min.css" />
    <link href="~/css/portal-lumen.css" rel="stylesheet" asp-append-version="true" />
</head>

<body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark shadow-sm">
        <div class="container">

            <a class="navbar-brand d-flex align-items-center" asp-controller="Dashboard" asp-action="Index">
                <img src="~/images/edahab-logo.png" class="portal-logo me-2" />
                <span>GST Portal</span>
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarColor02"
                    aria-controls="navbarColor02"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarColor02">

                <ul class="navbar-nav me-auto">

                    <!-- Dashboard -->
                    @if (User.HasPermission(AppPermissions.ViewDashboard))
                    {
                        <li class="nav-item">
                            <a asp-controller="Dashboard"
                               asp-action="Index"
                               class="nav-link @(controller == "Dashboard" ? "active" : "")">

                                <i class="fa-solid fa-chart-line me-1"></i>

                                Dashboard

                            </a>
                        </li>
                    }

                    <!-- Transactions -->
                    @if (User.HasPermission(AppPermissions.ViewTransactions))
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle @(controller == "Transactions" ? "active" : "")"
                               href="#"
                               data-bs-toggle="dropdown">

                                <i class="fa-solid fa-money-bill-transfer me-1"></i>

                                Transactions

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a asp-controller="Transactions"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-list me-2 text-primary"></i>

                                        Transactions

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Transactions"
                                       asp-action="Failed"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-circle-xmark me-2 text-danger"></i>

                                        Failed Deductions

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Transactions"
                                       asp-action="MinistryUpdates"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-building-columns me-2 text-success"></i>

                                        Ministry Updates

                                    </a>

                                </li>

                            </ul>

                        </li>
                    }

                    <!-- Merchants -->
                    @if (User.HasPermission(AppPermissions.ViewMerchants))
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle @(controller == "Merchants" ? "active" : "")"
                               href="#"
                               data-bs-toggle="dropdown">

                                <i class="fa-solid fa-store me-1"></i>

                                Merchants

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a asp-controller="Merchants"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-store me-2 text-success"></i>

                                        Merchant Management

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Merchants"
                                       asp-action="Import"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-file-import me-2 text-primary"></i>

                                        Import Merchants

                                    </a>

                                </li>

                            </ul>

                        </li>
                    }

                    <!-- Reports -->
                    @if (User.HasPermission(AppPermissions.ViewReports))
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                               href="#"
                               data-bs-toggle="dropdown">

                                <i class="fa-solid fa-chart-column me-1"></i>

                                Reports

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a asp-controller="Reports"
                                       asp-action="DailySummary"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-calendar-day me-2 text-primary"></i>

                                        Daily Summary

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Reports"
                                       asp-action="Transactions"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-file-lines me-2 text-success"></i>

                                        Transaction Report

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Reports"
                                       asp-action="Ministry"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-building-columns me-2 text-warning"></i>

                                        Ministry Report

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Reports"
                                       asp-action="Collection"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-sack-dollar me-2 text-success"></i>

                                        GST Collection

                                    </a>

                                </li>

                            </ul>

                        </li>
                    }

                    <!-- Security -->
                    @if (User.HasPermission(AppPermissions.ViewUsers) ||
                                        User.HasPermission(AppPermissions.ManageUsers))
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle @(controller == "Users" || controller == "Roles" || controller == "Permissions" ? "active" : "")"
                               href="#"
                               data-bs-toggle="dropdown">

                                <i class="fa-solid fa-user-shield me-1"></i>

                                Security

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <h6 class="dropdown-header">

                                        Security Management

                                    </h6>

                                </li>

                                @if (User.HasPermission(AppPermissions.ViewUsers))
                                {
                                    <li>

                                        <a asp-controller="Users"
                                           asp-action="Index"
                                           class="dropdown-item">

                                            <i class="fa-solid fa-users me-2 text-primary"></i>

                                            Users

                                        </a>

                                    </li>
                                }

                                @if (User.HasPermission(AppPermissions.ManageUsers))
                                {
                                    <li>

                                        <a asp-controller="Roles"
                                           asp-action="Index"
                                           class="dropdown-item">

                                            <i class="fa-solid fa-user-tag me-2 text-success"></i>

                                            Roles

                                        </a>

                                    </li>

                                    <li>

                                        <a asp-controller="Permissions"
                                           asp-action="Index"
                                           class="dropdown-item">

                                            <i class="fa-solid fa-key me-2 text-warning"></i>

                                            Permissions

                                        </a>

                                    </li>

                                    <li>

                                        <a asp-controller="AuditLogs"
                                           asp-action="Index"
                                           class="dropdown-item">

                                            <i class="fa-solid fa-clock-rotate-left me-2 text-info"></i>

                                            Audit Logs

                                        </a>

                                    </li>

                                }

                            </ul>

                        </li>
                    }

                    <!-- Administration -->
                    @if (User.HasPermission(AppPermissions.ManageSettings))
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                               href="#"
                               data-bs-toggle="dropdown">

                                <i class="fa-solid fa-gears me-1"></i>

                                Administration

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a asp-controller="Settings"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-sliders me-2 text-primary"></i>

                                        Settings

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="Jobs"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-server me-2 text-success"></i>

                                        Background Jobs

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="System"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        <i class="fa-solid fa-microchip me-2 text-warning"></i>

                                        System Information

                                    </a>

                                </li>

                            </ul>

                        </li>
                    }

                </ul>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               data-bs-toggle="dropdown"
                               href="#"
                               role="button"
                               aria-expanded="false">
                                <i class="fa-solid fa-user-shield me-1 text-success"></i>
                                @fullName
                                @if (!string.IsNullOrWhiteSpace(roleName))
                                {
                                    <span class="badge bg-success ms-1">@roleName</span>
                                }
                            </a>

                            <div class="dropdown-menu dropdown-menu-end">
                                <h6 class="dropdown-header">@fullName</h6>

                                <a asp-controller="Account" asp-action="Profile" class="dropdown-item">
                                    <i class="fa-solid fa-user me-2"></i>
                                    Profile
                                </a>

                                <a asp-controller="Account" asp-action="ChangePassword" class="dropdown-item">
                                    <i class="fa-solid fa-key me-2"></i>
                                    Change Password
                                </a>

                                <div class="dropdown-divider"></div>

                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i>
                                        Logout
                                    </button>
                                </form>
                            </div>
                        </li>
                    </ul>
                }

            </div>
        </div>
    </nav>

    <header class="page-header border-bottom bg-white">
        <div class="container py-3">
            <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
            <small class="text-muted">Merchant GST deduction and Ministry reporting</small>
        </div>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top bg-white py-3">
        <div class="container text-center">
            <strong>eDahab GST Reporting Portal</strong><br />
            <small class="text-muted">
                © @DateTime.Now.Year eDahab. All rights reserved.
            </small>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('.portal-table').DataTable({
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100],
                ordering: true,
                searching: true,
                responsive: true,
                language: {
                    search: "Search:",
                    lengthMenu: "Show _MENU_ records",
                    info: "Showing _START_ to _END_ of _TOTAL_ records",
                    paginate: {
                        previous: "Previous",
                        next: "Next"
                    }
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>