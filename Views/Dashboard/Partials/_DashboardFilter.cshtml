@model ReportFilter

<div class="card filter-card mb-4">
    <div class="card-body py-3">

        <form method="get">
            <div class="row g-3 align-items-end">

                <div class="col-xl-3 col-lg-4 col-md-6">
                    <label class="form-label">
                        <i class="fas fa-calendar-alt mr-1"></i>
                        Date From
                    </label>

                    <input type="date"
                           class="form-control"
                           name="FromDate"
                           value="@Model.FromDate.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-xl-3 col-lg-4 col-md-6">
                    <label class="form-label">
                        <i class="fas fa-calendar-check mr-1"></i>
                        Date To
                    </label>

                    <input type="date"
                           class="form-control"
                           name="ToDate"
                           value="@Model.ToDate.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-xl-3 col-lg-4 col-md-6">
                    <label class="form-label">
                        <i class="fas fa-coins mr-1"></i>
                        Currency
                    </label>

                    <select class="form-control" name="Currency">
                        <option value="101" selected="@(Model.Currency == "101")">USD</option>
                        <option value="102" selected="@(Model.Currency == "102")">SLS</option>
                    </select>
                </div>

                <div class="col-xl-3 col-lg-12 col-md-6">
                    <label class="form-label d-none d-xl-block">&nbsp;</label>

                    <div class="d-flex">
                        <button type="submit" class="btn btn-primary flex-grow-1 mr-2">
                            <i class="fas fa-filter mr-1"></i>
                            Filter
                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary reset-btn">
                            <i class="fas fa-rotate-right mr-1"></i>
                            Reset
                        </a>
                    </div>
                </div>

            </div>
        </form>

    </div>
</div>