@model DashboardSummary

<div class="row mb-4">

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card kpi-card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="kpi-title">Total Transactions</div>
                    <div class="kpi-value">@Model.TotalTransactions</div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-receipt"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card kpi-card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="kpi-title">Gross Amount</div>
                    <div class="kpi-value">@Model.GrossAmount.ToString("N2")</div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-money-bill-trend-up"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card kpi-card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="kpi-title">Tax Amount</div>
                    <div class="kpi-value">@Model.TaxAmount.ToString("N2")</div>
                </div>
                <div class="kpi-icon">
                    <i class="fa-solid fa-percent"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card kpi-card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="kpi-title">Ministry Pending</div>
                    <div class="kpi-value text-warning">@Model.MinistryPending</div>
                </div>
                <div class="kpi-icon warning">
                    <i class="fa-solid fa-clock"></i>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row mb-4">

    <div class="col-xl-4 col-md-6 mb-3">
        <div class="card status-card success">
            <div class="card-body">
                <i class="fa-solid fa-circle-check me-2"></i>
                Successful Deductions
                <strong>@Model.SuccessfulDeductions</strong>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-6 mb-3">
        <div class="card status-card pending">
            <div class="card-body">
                <i class="fa-solid fa-hourglass-half me-2"></i>
                Pending Deductions
                <strong>@Model.PendingDeductions</strong>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-6 mb-3">
        <div class="card status-card failed">
            <div class="card-body">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                Failed Deductions
                <strong>@Model.FailedDeductions</strong>
            </div>
        </div>
    </div>

</div>