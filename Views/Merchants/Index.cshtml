@model IEnumerable<Merchant>
@using SLMOFTaxPortal.Helpers   
@{
    ViewData["Title"] = "Merchant Management";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check me-2"></i>
        @TempData["Success"]
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="fa-solid fa-store text-success me-2"></i>
            <strong>Merchants</strong>
            <span class="badge bg-secondary ms-2">@Model.Count()</span>
        </div>

        @if (User.HasPermission("ManageMerchants"))
        {
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="fa-solid fa-plus me-1"></i>
                Add Merchant
            </a>
        }
    </div>

    <div class="card-body table-responsive">
        <table class="table table-hover table-striped align-middle portal-table">
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>Merchant Name</th>
                    <th>Merchant Number</th>
                    <th>Merchant Code</th>
                    <th>TIN</th>
                    <th>City</th>
                    <th>Region</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.UserID</td>
                        <td>@item.MerchantName</td>
                        <td>@item.MerchantNumber</td>
                        <td>@item.MerchantCode</td>
                        <td>@item.Tin</td>
                        <td>@item.City</td>
                        <td>@item.Region</td>
                        <td>
                            @if (item.Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details"
                                   asp-route-id="@item.UserID"
                                   class="btn btn-info">
                                    <i class="fa-solid fa-eye me-1"></i>
                                    View
                                </a>

                                @if (User.HasPermission("ManageMerchants"))
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.UserID"
                                       class="btn btn-primary">
                                        <i class="fa-solid fa-pen me-1"></i>
                                        Edit
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.UserID"
                                       class="btn btn-danger">
                                        <i class="fa-solid fa-trash me-1"></i>
                                        Delete
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>