@model RoleViewModel

<form method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="RoleName" class="form-label fw-bold">
                Role Name
            </label>
            <input asp-for="RoleName" class="form-control" placeholder="Example: Admin" />
            <span asp-validation-for="RoleName" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Description" class="form-label fw-bold">
                Description
            </label>
            <input asp-for="Description" class="form-control" placeholder="Role description" />
        </div>

        <div class="col-md-6">
            <div class="form-check form-switch mt-4">
                <input asp-for="Active" class="form-check-input" />
                <label asp-for="Active" class="form-check-label fw-bold">
                    Active
                </label>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-success">
            <i class="fa-solid fa-save me-1"></i>
            Save
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i>
            Back
        </a>
    </div>
</form>