@model IEnumerable<RoleViewModel>

@{
    ViewData["Title"] = "Roles Management";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check me-2"></i>
        @TempData["Success"]
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="fa-solid fa-user-shield text-success me-2"></i>
            <strong>Roles</strong>
            <span class="badge bg-secondary ms-2">@Model.Count()</span>
        </div>

        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="fa-solid fa-plus me-1"></i>
            Add Role
        </a>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-hover table-striped align-middle portal-table">
            <thead>
                <tr>
                    <th>Role Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.RoleName</td>
                        <td>@item.Description</td>
                        <td>
                            @if (item.Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary">
                                    <i class="fa-solid fa-pen me-1"></i>
                                    Edit
                                </a>

                                <a asp-action="Permissions"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info">
                                    <i class="fa-solid fa-lock me-1"></i>
                                    Permissions
                                </a>

                                <a asp-action="Disable"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger"
                                   onclick="return confirm('Disable this role?');">
                                    <i class="fa-solid fa-ban me-1"></i>
                                    Disable
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>