@model IEnumerable<PermissionViewModel>

@{
    ViewData["Title"] = "Permission Management";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="fa-solid fa-circle-check me-2"></i>
        @TempData["Success"]
    </div>
}

<div class="card">

    <div class="card-header d-flex justify-content-between align-items-center">

        <div>

            <i class="fa-solid fa-key text-warning me-2"></i>

            <strong>Permission Definitions</strong>

            <span class="badge bg-secondary ms-2">
                @Model.Count()
            </span>

        </div>

        <a asp-action="Create"
           class="btn btn-success">

            <i class="fa-solid fa-plus me-1"></i>

            Add Permission

        </a>

    </div>

    <div class="card-body">

        <table class="table table-hover table-striped portal-table align-middle">

            <thead>

                <tr>

                    <th>Code</th>

                    <th>Name</th>

                    <th>Module</th>

                    <th>Description</th>

                    <th>Status</th>

                    <th class="text-end">Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>

                            <code>@item.PermissionCode</code>

                        </td>

                        <td>

                            @item.PermissionName

                        </td>

                        <td>

                            <span class="badge bg-info">

                                @item.Module

                            </span>

                        </td>

                        <td>

                            @item.Description

                        </td>

                        <td>

                            @if (item.Active)
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Disabled
                                </span>
                            }

                        </td>

                        <td class="text-end">

                            <div class="btn-group btn-group-sm">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary">

                                    <i class="fa-solid fa-pen me-1"></i>

                                    Edit

                                </a>

                                <a asp-action="Disable"
                                   asp-route-id="@item.Id"
                                   onclick="return confirm('Disable this permission?');"
                                   class="btn btn-outline-danger">

                                    <i class="fa-solid fa-ban me-1"></i>

                                    Disable

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>